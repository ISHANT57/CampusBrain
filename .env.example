# Copy to .env and adjust if needed. Dev-only defaults — never used in production.

POSTGRES_USER=campusbrain
POSTGRES_PASSWORD=campusbrain_dev
POSTGRES_DB=campusbrain
POSTGRES_PORT=5432

MINIO_ROOT_USER=campusbrain
MINIO_ROOT_PASSWORD=campusbrain_dev
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

QDRANT_PORT=6333

# Dev-only secret. Real deployments generate a random one and inject it
# via a secrets manager (see M60), never commit a real value here.
JWT_SECRET_KEY=dev_only_insecure_secret_change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Get a key at https://openrouter.ai/keys. Never commit the real value.
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-20b:free

# Embeddings. Get a free-tier key at https://aistudio.google.com/apikey.
# Never commit the real value. embedding_dim must match output_dimensionality
# in gemini_provider.py — if you change EMBEDDING_DIM, every org's Qdrant
# collection is recreated on next use (see vector_store.ensure_collection)
# and existing documents must be reprocessed to be searchable again.
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
