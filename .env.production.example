# Copy to .env.production on the server and fill in real values.
# .env.production is gitignored — never commit the filled-in file.
#
#   cp .env.production.example .env.production
#
# If deploying to Render + Vercel (the current path): Render's dashboard env
# var UI takes these directly, not this file — copy each value in individually.
# This file matters if you're using docker-compose.prod.yml instead (the
# self-hosted-VPS alternative).
#
# The host-port variables from .env.example are gone on purpose: in the VPS
# path, nothing but nginx publishes a port, so Postgres/Qdrant are reachable
# only over the internal Docker network and need no host mapping.

# --- Postgres ---------------------------------------------------------------
# Neon (the Render path): set DATABASE_URL to Neon's connection string
# verbatim (includes ?sslmode=require&channel_binding=require) and leave
# POSTGRES_USER/PASSWORD/DB/HOST blank — DATABASE_URL takes priority when set
# (config.py's database_url property).
DATABASE_URL=

# Self-hosted Postgres (VPS path only) — leave DATABASE_URL blank and fill
# these in instead.
POSTGRES_USER=campusbrain
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=campusbrain

# --- Vector database (Qdrant) ------------------------------------------------
# Qdrant Cloud (the Render path): set both. Get them from your cluster's
# dashboard page. Takes priority over QDRANT_HOST/QDRANT_INTERNAL_PORT below
# when set.
QDRANT_URL=
QDRANT_API_KEY=

# Self-hosted Qdrant (VPS path only) — leave QDRANT_URL blank; the defaults
# below already point at the qdrant service in docker-compose.prod.yml.
QDRANT_HOST=qdrant
QDRANT_INTERNAL_PORT=6333

# --- Object storage (Supabase Storage, S3-compatible) ----------------------
# Supabase dashboard -> Storage -> New bucket (name "documents", Private)
# -> Storage -> Settings -> S3 Connection -> New access key. Endpoint and
# region are shown on that same settings page.
STORAGE_ENDPOINT=https://<project_ref>.storage.supabase.co/storage/v1/s3
STORAGE_REGION=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET_NAME=documents

# --- CORS -------------------------------------------------------------------
# Comma-separated. MUST be your real Vercel origin(s), not "*" — "*" in
# production means any website can call this API using a logged-in user's
# browser session.
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# --- Auth ---------------------------------------------------------------
# MUST be a fresh random value. Reusing the dev default lets anyone forge a
# valid session token for any account.
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- LLM ----------------------------------------------------------------
# Answers come from Gemini, using GEMINI_API_KEY below. Nothing to set here
# unless you want a model other than the default (gemini-3.5-flash-lite).
GEMINI_LLM_MODEL=

# Only read if get_llm_provider() is switched back to OpenRouterProvider —
# its free tier caps at 50 requests per DAY, which the chatbot exhausts.
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-20b:free

# --- Embeddings -----------------------------------------------------------
# https://aistudio.google.com/apikey (free tier)
# Changing EMBEDDING_MODEL/EMBEDDING_DIM recreates every org's Qdrant
# collection on next use (backend/MIGRATION.md) — existing documents will
# need reprocessing afterward to be searchable again.
GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
