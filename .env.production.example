# Copy to .env.production on the server and fill in real values.
# .env.production is gitignored — never commit the filled-in file.
#
#   cp .env.production.example .env.production
#
# The host-port variables from .env.example are gone on purpose: in production
# nothing but nginx publishes a port, so Postgres/Redis/MinIO/Qdrant/Ollama are
# reachable only over the internal Docker network and need no host mapping.

# --- Postgres -----------------------------------------------------------
POSTGRES_USER=campusbrain
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=
POSTGRES_DB=campusbrain

# --- MinIO --------------------------------------------------------------
MINIO_ROOT_USER=
# Generate: openssl rand -base64 32
MINIO_ROOT_PASSWORD=

# --- Auth ---------------------------------------------------------------
# MUST be a fresh random value. Reusing the dev default lets anyone forge a
# valid session token for any account.
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- LLM ----------------------------------------------------------------
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-20b:free
